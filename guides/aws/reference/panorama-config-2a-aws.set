# ═════════════════════════════════════════════════════════════════════
#  panorama-config-2a-aws.set
#
#  Reference Panorama configuration for the AWS VM-Series Deployment
#  guide. Mirrors phases 2A.3 through 2A.14. Generated by
#  scripts/build-panorama-set.sh from a working Panorama 11.2.x
#  deployment, scrubbed of all credential material.
#
#  HOW TO USE:
#  1. SSH into Panorama as a superuser, drop to configure mode:
#         > set cli pager off
#         > configure
#  2. Paste this entire file (or section-by-section) into the CLI.
#  3. Run `validate full` to catch any dependency or syntax errors.
#  4. `commit` (Panorama-side) and then `commit-all` to push to firewalls.
#
#  YOU MUST EDIT THESE BEFORE COMMITTING:
#  - AUTHCODE-FROM-CSP        → real auth code from your CSP deployment profile
#  - <YOUR-POOL-ID>           → real credit pool ID
#  - $INTERNAL-GW / $EXTERNAL-GW values per AZ stack (per-AZ subnet gateways)
#  - DNS / NTP server IPs in 2-TPL if you don't use the AWS-native ones
#
#  CREDENTIALS NOT IN THIS FILE (build manually in the Panorama UI):
#  - Local admin accounts (mgt-config users) — usernames, password hashes, SSH keys
#  - RADIUS / TACACS server-profile shared secrets
#  - LDAP server-profile bind passwords
#  - Authentication profile / sequence / role mappings
#  - SSL certificates (key material) — use Device > Certificates > Generate / Import
#  Per-environment credentials must NEVER appear in a shared reference file.
#  See AWS guide section 2A.7 "Authentication" subsections for the UI walkthrough.
#
#  MANUAL UI STEP (no CLI equivalent):
#  - Panorama > Device Groups > DG-AWS-COMBINED → set Parent to DG-AWS.
#    Panorama manages parent-dg in its readonly section.
#
#  ROUTING-MODEL CHOICE:
#  This file includes BOTH overlay and non-overlay templates and stacks.
#  Keep what you'll use:
#  - Overlay     — keep 4-TPL-AWS-GWLB-OVRLY-COMBINED + STK-AWS-COMBINED-AZ-A
#  - Non-Overlay — keep 4-TPL-AWS-GWLB-NON-OVRLY-COMBINED + STK-AWS-COMBINED-NON-OVRLY-AZ
#  See AWS guide section 2A.8 for the routing-model trade-off.
# ═════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════
# SECTION 1 — SHARED TAGS (rule grouping + dynamic-group filters)
# ═════════════════════════════════════════════════════════════════════
set shared tag INBOUND color color1
set shared tag INBOUND comments "INBOUND FLOW"
set shared tag OUTBOUND color color13
set shared tag OUTBOUND comments "OUTBOUND FLOW"
set shared tag EASTWEST color color13
set shared tag EASTWEST comments "EAST/WEST POLICY"
set shared tag AWS-HEALTH-GWLB color color24
set shared tag AWS-HEALTH-GWLB comments "HEALTH PROBES"
set shared tag AWS-FW-DATA-PRIVATE color color24
set shared tag AWS-FW-DATA-PRIVATE comments FW-Data-plane-interface
set shared tag BASELINE color color15
set shared tag BASELINE comments "BASELINE CONFIG ELEMENTS"
set shared tag EXAMPLE color color6
set shared tag EXAMPLE comments "EXAMPLE ELEMENT OR POLICY"
set shared tag APP1 color color2
set shared tag APP1 comments APP1-ELEMENTS
set shared tag APP2 color color17
set shared tag APP2 comments APP2-ELEMENTS
set shared tag APP3 color color9
set shared tag ALB color color9
set shared tag ALB comments NLB-ELEMENTS
set shared tag OVERLAY-NAT color color6
set shared tag AWS-WEB-FARM-APP1 color color22
set shared tag AWS-WEB-FARM-APP1 comments INTERNAL
set shared tag PALO-GP-GATEWAY color color1
set shared tag PALO-GP-GATEWAY comments PALO-GP-GATEWAY

# ═════════════════════════════════════════════════════════════════════
# SECTION 2 — SHARED ADDRESS OBJECTS (H- single host, N- network range)
# ═════════════════════════════════════════════════════════════════════
# Convention: H-<ip> for single hosts, N-<network>-<prefix> for ranges.
# Tags drive the dynamic address-group filters in section 3.
set shared address H-199.167.52.5 description PALO-ALTO-CALIFORNIA-GP-GATEWAY
set shared address H-199.167.52.5 ip-netmask 199.167.52.5
set shared address H-199.167.52.5 tag [ INBOUND BASELINE PALO-GP-GATEWAY ]
set shared address H-APP2-WEB-ALB-FQDN description app2-ALB1-1305844078.us-west-2.elb.amazonaws.com
set shared address H-APP2-WEB-ALB-FQDN fqdn app2-ALB1-1305844078.us-west-2.elb.amazonaws.com
set shared address H-APP2-WEB-ALB-FQDN tag [ APP2 ALB BASELINE ]
set shared address N-10.0.0.0-8 description RFC-1918-10
set shared address N-10.0.0.0-8 ip-netmask 10.0.0.0/8
set shared address N-10.0.0.0-8 tag BASELINE
set shared address N-10.103.32.48-28 description GWLB-SUBNET-A
set shared address N-10.103.32.48-28 ip-netmask 10.103.32.48/28
set shared address N-10.103.32.48-28 tag AWS-HEALTH-GWLB
set shared address N-10.103.32.64-28 description FIREWALL-PRIVATE-SUBNET-A
set shared address N-10.103.32.64-28 ip-netmask 10.103.32.64/28
set shared address N-10.103.32.64-28 tag AWS-FW-DATA-PRIVATE
set shared address N-10.103.33.48-28 description GWLB-SUBNET-B
set shared address N-10.103.33.48-28 ip-netmask 10.103.33.48/28
set shared address N-10.103.33.48-28 tag AWS-HEALTH-GWLB
set shared address N-10.103.33.64-28 description FIREWALL-PRIVATE-SUBNET-B
set shared address N-10.103.33.64-28 ip-netmask 10.103.33.64/28
set shared address N-10.103.33.64-28 tag AWS-FW-DATA-PRIVATE
set shared address N-10.103.34.48-28 description GWLB-SUBNET-C
set shared address N-10.103.34.48-28 ip-netmask 10.103.34.48/28
set shared address N-10.103.34.48-28 tag AWS-HEALTH-GWLB
set shared address N-10.103.35.48-28 description GWLB-SUBNET-D
set shared address N-10.103.35.48-28 ip-netmask 10.103.35.48/28
set shared address N-10.103.35.48-28 tag AWS-HEALTH-GWLB
set shared address N-10.104.0.0-22 description APP1-VPC
set shared address N-10.104.0.0-22 ip-netmask 10.104.0.0/22
set shared address N-10.104.0.0-22 tag [ AWS-WEB-FARM-APP1 BASELINE ]
set shared address N-10.105.0.0-22 description APP2-VPC
set shared address N-10.105.0.0-22 ip-netmask 10.105.0.0/22
set shared address N-10.105.0.0-22 tag [ APP2 BASELINE ]
set shared address N-10.106.0.0-22 description APP3-VPC
set shared address N-10.106.0.0-22 ip-netmask 10.106.0.0/22
set shared address N-10.106.0.0-22 tag [ APP3 BASELINE ]

# ═════════════════════════════════════════════════════════════════════
# SECTION 3 — SHARED ADDRESS GROUPS (dynamic, tag-filter based)
# ═════════════════════════════════════════════════════════════════════
# These resolve at policy-evaluation time to whatever address objects
# carry the matching tag. Add new addresses with the right tag and they
# automatically join the group — no group edits needed.
set shared address-group GRP-AWS-GWLB-HEALTH-PROBE-SUBNETS dynamic filter "'AWS-HEALTH-GWLB'"
set shared address-group GRP-AWS-GWLB-HEALTH-PROBE-SUBNETS tag AWS-HEALTH-GWLB
set shared address-group GRP-FIREWALL-PRIVATE-SUBNETS dynamic filter "'AWS-FW-DATA-PRIVATE'"
set shared address-group GRP-FIREWALL-PRIVATE-SUBNETS tag AWS-FW-DATA-PRIVATE

# ═════════════════════════════════════════════════════════════════════
# SECTION 4 — SHARED PROFILE GROUPS (Outbound, Inbound, Internal, Alert-Only, default)
# ═════════════════════════════════════════════════════════════════════
# References to AS / VP / URL / FB / WF / AV profiles must already exist.
# If they don't, build them in Objects > Security Profiles first OR
# clone from the predefined 'strict' set.
set shared profile-group Outbound spyware Outbound-AS
set shared profile-group Outbound vulnerability Outbound-VP
set shared profile-group Outbound url-filtering Outbound-URL
set shared profile-group Outbound file-blocking Outbound-FB
set shared profile-group Outbound wildfire-analysis Outbound-WF
set shared profile-group Outbound virus Outbound-AV
set shared profile-group Inbound spyware Inbound-AS
set shared profile-group Inbound vulnerability Inbound-VP
set shared profile-group Inbound file-blocking Inbound-FB
set shared profile-group Inbound wildfire-analysis Inbound-WF
set shared profile-group Inbound virus Inbound-AV
set shared profile-group Internal spyware Internal-AS
set shared profile-group Internal vulnerability Internal-VP
set shared profile-group Internal file-blocking Internal-FB
set shared profile-group Internal wildfire-analysis Internal-WF
set shared profile-group Internal virus Internal-AV
set shared profile-group Alert-Only spyware Alert-Only-AS
set shared profile-group Alert-Only vulnerability Alert-Only-VP
set shared profile-group Alert-Only url-filtering Alert-Only-URL
set shared profile-group Alert-Only file-blocking Alert-Only-FB
set shared profile-group Alert-Only wildfire-analysis Alert-Only-WF
set shared profile-group Alert-Only virus Alert-Only-AV
set shared profile-group default spyware Outbound-AS
set shared profile-group default vulnerability Outbound-VP
set shared profile-group default url-filtering Outbound-URL
set shared profile-group default file-blocking Outbound-FB
set shared profile-group default wildfire-analysis Outbound-WF
set shared profile-group default virus Outbound-AV

# ═════════════════════════════════════════════════════════════════════
# SECTION 5 — TEMPLATE 1-TPL-AWS-REGIONAL-USW2 (region-specific)
# ═════════════════════════════════════════════════════════════════════
set template 1-TPL-AWS-REGIONAL-USW2 description US-WEST-REGIONAL-TEMPLATE-FOR-REGIONAL-TACACS-AND-LOG-COLLECTORS
set template 1-TPL-AWS-REGIONAL-USW2 settings default-vsys vsys1
set template 1-TPL-AWS-REGIONAL-USW2 config  vsys vsys1
set template 1-TPL-AWS-REGIONAL-USW2 config shared server-profile radius RADIUS-SERVER protocol PAP
set template 1-TPL-AWS-REGIONAL-USW2 config shared server-profile radius RADIUS-SERVER server RADIUS-SERVER port 1812
set template 1-TPL-AWS-REGIONAL-USW2 config shared server-profile radius RADIUS-SERVER server RADIUS-SERVER ip-address 1.1.1.1

# ═════════════════════════════════════════════════════════════════════
# SECTION 6 — TEMPLATE 2-TPL-AWS-GLOBAL-COMMON-BASELINE (DNS/NTP/Panorama/log-fwd)
# ═════════════════════════════════════════════════════════════════════
# REVIEW: DNS/NTP server IPs, Panorama server IP, login banners, log forwarding.
# Your environment may use different DNS/NTP than what's exported here.
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE description "COMMON SETTINGS DNS, NTP, BANNERS"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  vsys vsys1
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system update-server updates.paloaltonetworks.com
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system dns-setting servers primary 8.8.8.8
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system dns-setting servers secondary 8.8.4.4
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system ntp-servers primary-ntp-server ntp-server-address 0.pool.ntp.org
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system ntp-servers secondary-ntp-server ntp-server-address 1.pool.ntp.org
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system type dhcp-client send-client-id no
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system type dhcp-client send-hostname yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system type dhcp-client accept-dhcp-hostname no
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system type dhcp-client accept-dhcp-domain no
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner motd-enable yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner message "!!!! DO NOT MAKE CHANGES ON THE LOCAL FIREWALL. MAKE ALL CHANGES ON PANORAMA. MAKE SURE YOU HAVE CAB APPROVAL PRIOR TO MAKING ANY CHANGES. !!!"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner motd-color color1
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner severity warning
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner banner-header "!!! THIS IS A FIREWALL. !!!"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner banner-header-color color1
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system motd-and-banner banner-header-text-color color18
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system panorama local-panorama panorama-server 10.255.247.51
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system panorama local-panorama panorama-server-2 10.255.247.151
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system domain variable.com
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system timezone UTC
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig system login-banner "!!!! GET OUT !!!!!"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig setting ctd x-forwarded-for 2
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig setting wildfire report-benign-file yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config  deviceconfig setting wildfire report-grayware-file yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings system match-list system filter "All Logs"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings system match-list system send-to-panorama yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings config match-list config filter "All Logs"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings config match-list config send-to-panorama yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings userid match-list user-id filter "All Logs"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings userid match-list user-id send-to-panorama yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings iptag match-list ip-tag filter "All Logs"
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared log-settings iptag match-list ip-tag send-to-panorama yes
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared server-profile radius RADIUS-SERVER protocol PAP
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared server-profile radius RADIUS-SERVER server RADIUS-SERVER port 1812
set template 2-TPL-AWS-GLOBAL-COMMON-BASELINE config shared server-profile radius RADIUS-SERVER server RADIUS-SERVER ip-address 3.3.3.3

# ═════════════════════════════════════════════════════════════════════
# SECTION 7 — TEMPLATE 3-TPL-AWS-ADMINS-BASELINE (placeholder)
# ═════════════════════════════════════════════════════════════════════
# This section ONLY contains the template scaffold + DHCP client settings.
#
# The following content is INTENTIONALLY NOT INCLUDED — build it manually
# per AWS guide 2A.7 'Authentication' subsections, in the Panorama UI:
#   - Local admin user accounts (Device > Administrators)
#   - Password hashes
#   - SSH public keys for admin users
#   - RADIUS / TACACS server profiles + shared secrets
#   - LDAP server profiles + bind passwords
#   - Authentication profiles + sequences
#   - Admin role profiles
#
# Reason: these contain credentials that must NEVER appear in a shared
# reference file. They are environment-specific and must be entered
# directly in the Panorama UI (or via secrets-management tooling).
set template 3-TPL-AWS-ADMINS-BASELINE config  vsys vsys1
set template 3-TPL-AWS-ADMINS-BASELINE config  deviceconfig system panorama local-panorama panorama-server 1.1.1.1
set template 3-TPL-AWS-ADMINS-BASELINE config  deviceconfig system type dhcp-client send-client-id yes
set template 3-TPL-AWS-ADMINS-BASELINE config  deviceconfig system type dhcp-client send-hostname yes
set template 3-TPL-AWS-ADMINS-BASELINE config  deviceconfig system type dhcp-client accept-dhcp-hostname no
set template 3-TPL-AWS-ADMINS-BASELINE config  deviceconfig system type dhcp-client accept-dhcp-domain no
set template 3-TPL-AWS-ADMINS-BASELINE description "ADMIN ACCOUNTS, LDAP, RADIUS"

# ═════════════════════════════════════════════════════════════════════
# SECTION 8 — TEMPLATE 4-TPL-AWS-GWLB-OVRLY-COMBINED (overlay routing — KEEP if overlay)
# ═════════════════════════════════════════════════════════════════════
# Use with STK-AWS-COMBINED-AZ-A (section 10).
# Includes ethernet1/1, ethernet1/1.{10,20,30,10x} subinterfaces,
# ethernet1/2 with CUSTOMER-INTERNET-PING profile, AWS-LR with
# RFC1918 + DEFAULT static routes using $INTERNAL-GW / $EXTERNAL-GW.
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED description "Network Settings: interfaces, zones, routing"
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile AWS-HEALTH-CHECKS https yes
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile AWS-HEALTH-CHECKS http yes
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile AWS-HEALTH-CHECKS ssh no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile AWS-HEALTH-CHECKS permitted-ip 10.0.0.0/8
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile PUBLIC-PING permitted-ip 199.167.52.5
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile PUBLIC-PING ping yes
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile INTERNAL-PING permitted-ip 10.0.0.0/8
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile INTERNAL-PING permitted-ip 172.16.0.0/12
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile INTERNAL-PING permitted-ip 192.168.0.0/16
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network profiles interface-management-profile INTERNAL-PING ping yes
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 ndp-proxy enabled no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 sdwan-link-settings upstream-nat enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 sdwan-link-settings upstream-nat static-ip
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 sdwan-link-settings enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 sdwan-link-settings ipv6-enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 interface-management-profile AWS-HEALTH-CHECKS
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 lldp enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 dhcp-client create-default-route no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 dhcp-client send-hostname enable yes
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 tag 20
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 comment OUTBOUND
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 dhcp-client create-default-route no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 sdwan-link-settings enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 sdwan-link-settings upstream-nat enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 sdwan-link-settings ipv6-enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 ndp-proxy enabled no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.20 adjust-tcp-mss enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 tag 30
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 comment EASTWEST
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 dhcp-client create-default-route no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 ndp-proxy enabled no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 sdwan-link-settings enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 sdwan-link-settings upstream-nat enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 sdwan-link-settings ipv6-enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.30 adjust-tcp-mss enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 sdwan-link-settings upstream-nat enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 sdwan-link-settings upstream-nat static-ip
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 sdwan-link-settings enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 sdwan-link-settings ipv6-enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 ndp-proxy enabled no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 adjust-tcp-mss enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 dhcp-client create-default-route no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 tag 10
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.10 comment INBOUND
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.101 sdwan-link-settings upstream-nat enable no
set template 4-TPL-AWS-GWLB-OVRLY-COMBINED config  network interface ethernet ethernet1/1 layer3 units ethernet1/1.101 sdwan-link-settings upstream-nat static-ip
