# ═════════════════════════════════════════════════════════════════════
# SECTION 10 — TEMPLATE STACK STK-AWS-COMBINED-AZ-A (overlay — KEEP if overlay)
# ═════════════════════════════════════════════════════════════════════
# Replicate this stack per AZ (STK-AWS-COMBINED-AZ-B, -AZ-C) with
# different $INTERNAL-GW / $EXTERNAL-GW values for each AZ's subnets.
set template-stack STK-AWS-COMBINED-AZ-A templates [ 1-TPL-AWS-REGIONAL-USW2 2-TPL-AWS-GLOBAL-COMMON-BASELINE 3-TPL-AWS-ADMINS-BASELINE 4-TPL-AWS-GWLB-OVRLY-COMBINED ]
set template-stack STK-AWS-COMBINED-AZ-A auto-push-on-1st-conn yes
set template-stack STK-AWS-COMBINED-AZ-A settings default-vsys vsys1
set template-stack STK-AWS-COMBINED-AZ-A variable $EXTERNAL-GW type ip-netmask 10.103.32.97
set template-stack STK-AWS-COMBINED-AZ-A variable $INTERNAL-GW type ip-netmask 10.103.32.65
set template-stack STK-AWS-COMBINED-AZ-A config devices localhost.localdomain deviceconfig system type dhcp-client accept-dhcp-hostname yes
set template-stack STK-AWS-COMBINED-AZ-A config devices localhost.localdomain deviceconfig system type dhcp-client accept-dhcp-domain yes
set template-stack STK-AWS-COMBINED-AZ-A config devices localhost.localdomain deviceconfig system type dhcp-client send-hostname yes
set template-stack STK-AWS-COMBINED-AZ-A config devices localhost.localdomain deviceconfig system type dhcp-client send-client-id no
set template-stack STK-AWS-COMBINED-AZ-A description AWS-COMBINED-AZ-A

# ═════════════════════════════════════════════════════════════════════
# SECTION 11 — TEMPLATE STACK STK-AWS-COMBINED-NON-OVRLY-AZ (non-overlay — KEEP if non-overlay)
# ═════════════════════════════════════════════════════════════════════
set template-stack STK-AWS-COMBINED-NON-OVRLY-AZ templates [ 1-TPL-AWS-REGIONAL-USW2 2-TPL-AWS-GLOBAL-COMMON-BASELINE 3-TPL-AWS-ADMINS-BASELINE 4-TPL-AWS-GWLB-NON-OVRLY-COMBINED ]
set template-stack STK-AWS-COMBINED-NON-OVRLY-AZ settings default-vsys vsys1
set template-stack STK-AWS-COMBINED-NON-OVRLY-AZ description NON-OVRLY-GWLB-AZ-A-B
set template-stack STK-AWS-COMBINED-NON-OVRLY-AZ auto-push-on-1st-conn yes

# ═════════════════════════════════════════════════════════════════════
# SECTION 12 — DEVICE GROUP DG-AWS (parent — shared rules + objects)
# ═════════════════════════════════════════════════════════════════════
# Reminder: After loading, set DG-AWS-COMBINED's parent to DG-AWS
# in the Panorama UI (Panorama > Device Groups > DG-AWS-COMBINED).

# ═════════════════════════════════════════════════════════════════════
# SECTION 13 — DEVICE GROUP DG-AWS-COMBINED (security + NAT policy)
# ═════════════════════════════════════════════════════════════════════
# All AWS-specific security and NAT rules live here. Pre-rulebase rules
# include AWS-HEALTH-PROBE (GWLB health checks) and per-flow rules.
# Tags drive grouping and filtering.
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE target negate no
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE to GWLB
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE from GWLB
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE source-user any
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE category any
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE application [ ssl web-browsing ]
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE service [ service-http service-https ]
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE source-hip any
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE destination-hip any
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE action allow
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE disabled no
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE tag [ AWS-HEALTH-GWLB BASELINE EXAMPLE ]
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE group-tag AWS-HEALTH-GWLB
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE source GRP-AWS-GWLB-HEALTH-PROBE-SUBNETS
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE destination GRP-FIREWALL-PRIVATE-SUBNETS
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE log-end no
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE log-setting default
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE log-start no
set device-group DG-AWS-COMBINED pre-rulebase security rules AWS-HEALTH-PROBE description "POLICY FOR GWLB HEALTH PROBES FROM GATEWAY LOAD BALANCER TO FIREWALL PRIVATE DATA PLANE INTERFACES"
set device-group DG-AWS-COMBINED pre-rulebase security rules SSH-INBOUND target negate no
set device-group DG-AWS-COMBINED pre-rulebase security rules SSH-INBOUND to [ APP1-DISTRIBUTED-INBOUND APP2-DISTRIBUTED-INBOUND APP3-DISTRIBUTED-INBOUND ]
set device-group DG-AWS-COMBINED pre-rulebase security rules SSH-INBOUND from [ APP1-DISTRIBUTED-INBOUND APP2-DISTRIBUTED-INBOUND APP3-DISTRIBUTED-INBOUND ]
