# ═════════════════════════════════════════════════════════════════════
# SECTION 14 — SW FIREWALL LICENSE PLUGIN (bootstrap-definition + license-manager)
# ═════════════════════════════════════════════════════════════════════
# REPLACE AUTHCODE-FROM-CSP with your real auth code from the CSP
# deployment profile. Replace <YOUR-POOL-ID> with your actual pool ID.
set plugins sw_fw_license bootstrap-definition bsd-aws-combined authcode AUTHCODE-FROM-CSP
set plugins sw_fw_license bootstrap-definition bsd-aws-combined description "Credit Pool ID: <YOUR-POOL-ID>"
set plugins sw_fw_license license-manager lm-aws-combined device-group DG-AWS-COMBINED
set plugins sw_fw_license license-manager lm-aws-combined template-stack STK-AWS-COMBINED-AZ-A
set plugins sw_fw_license license-manager lm-aws-combined bootstrap-definition bsd-aws-combined
set plugins sw_fw_license license-manager lm-aws-combined auto-deactivate Never

# ═════════════════════════════════════════════════════════════════════
#  POST-LOAD CHECKLIST
# ═════════════════════════════════════════════════════════════════════
# 1. Set DG-AWS-COMBINED parent to DG-AWS via UI (Panorama > Device Groups).
# 2. Replace AUTHCODE-FROM-CSP with your real auth code.
# 3. Verify $INTERNAL-GW / $EXTERNAL-GW IPs match your AZ-A subnet gateways.
# 4. Build the AAA configuration in 3-TPL-AWS-ADMINS-BASELINE per AWS guide 2A.7.
# 5. (Optional) Add per-AZ stacks: STK-AWS-COMBINED-AZ-B, -AZ-C with their AZ's IPs.
# 6. Run `validate full` and resolve any errors.
# 7. `commit` to Panorama, then `commit-all` to push to firewalls.
# 8. After firewalls bootstrap, click 'Show Bootstrap Parameters' on the License
#    Manager and copy auth-key + plugin-op-commands into your Terraform tfvars.
